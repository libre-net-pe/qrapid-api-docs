{
  "name": "@libre-net-pe/qrapid-sdk",
  "version": "0.1.4",
  "description": "Type-safe TypeScript client for the QRapid API",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsup"
  },
  "dependencies": {
    "openapi-fetch": "^0.13"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^5"
  },
  "peerDependencies": {
    "typescript": ">=5"
  }
}
